-
    var blogArchiveData = typeof blogArchiveSection === "object" && blogArchiveSection ? blogArchiveSection : {}
    var blogArchiveButtonData = typeof blogArchiveData.button === "object" && blogArchiveData.button ? blogArchiveData.button : {}
    var blogArchiveOptions = Object.assign({}, blogArchiveDefaults, blogArchiveData)
    var blogArchiveButton = Object.assign({}, blogArchiveDefaults.button, blogArchiveButtonData)
    var blogArchiveItems = Array.isArray(blogArchiveData.items) && blogArchiveData.items.length ? blogArchiveData.items : blogArchiveDefaults.items

section.blog-archive(
    data-blog-archive
    data-initial-desktop=blogArchiveOptions.initialDesktop
    data-initial-mobile=blogArchiveOptions.initialMobile
    data-step-desktop=blogArchiveOptions.stepDesktop
    data-step-mobile=blogArchiveOptions.stepMobile
)
    ._container
        .blog-archive__wrapper
            .blog-archive__hero
                .blog-archive__content
                    .blog-archive__head
                        h1.blog-archive__title.ui-title
                            each line, index in blogArchiveOptions.titleLines
                                | #{line}
                                if index !== blogArchiveOptions.titleLines.length - 1
                                    br
                    .blog-archive__copy
                        p.blog-archive__text.ui-text= blogArchiveOptions.textTop
                        p.blog-archive__text.ui-text= blogArchiveOptions.textBottom
                .blog-archive__hero-media
                    +mediaImage({
                        src: blogArchiveOptions.heroImageSrc,
                        srcset: blogArchiveOptions.heroImageSrcset,
                        webpSrcset: blogArchiveOptions.heroImageWebpSrcset,
                        alt: blogArchiveOptions.heroImageAlt,
                        width: blogArchiveOptions.heroImageWidth,
                        height: blogArchiveOptions.heroImageHeight,
                        loading: "eager",
                        decoding: "async",
                        fetchpriority: "high",
                        sizes: "(max-width: 650px) 100vw, 46vw"
                    })

            .blog-archive__grid
                each item, index in blogArchiveItems
                    .blog-archive__item(data-blog-item data-item-index=index)
                        +blogCard(item)

            .blog-archive__footer(data-blog-footer)
                .blog-archive__loader(data-blog-loader aria-hidden="true")
                    img(src="/static/images/section/blog-archive/blog-archive-loader.svg" alt="" loading="lazy")
                button.blog-archive__more.ui-btn.ui-btn--primary(type="button" data-blog-more)
                    span.ui-btn__content
                        span.blog-archive__more-label.blog-archive__more-label--default= blogArchiveButton.label
                        span.blog-archive__more-label.blog-archive__more-label--loading= blogArchiveButton.loadingLabel
