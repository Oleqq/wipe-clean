section.services-benefits
    ._container
        .services-benefits__wrapper
            .services-benefits__intro
                .services-benefits__head.ui-section-head
                    h2.ui-title.services-benefits__title= servicesBenefits.title
                    p.ui-text.services-benefits__text= servicesBenefits.text
                .services-benefits__slider.swiper(data-services-benefits-swiper)
                    .services-benefits__cards.swiper-wrapper
                        each item in servicesBenefits.cards
                            .services-benefits__slide.swiper-slide
                                +featureCard(item)
            .services-benefits__details
                .services-benefits__offer
                    .services-benefits__offer-content
                        h3.ui-title.services-benefits__offer-title= servicesBenefits.offer.title
                        p.ui-text.services-benefits__offer-text= servicesBenefits.offer.text
                    a.ui-btn.services-benefits__offer-action(class=servicesBenefits.offer.button.className href=servicesBenefits.offer.button.href)
                        span.ui-btn__content= servicesBenefits.offer.button.label
                .services-benefits__checklist
                    h3.ui-title.services-benefits__checklist-title= servicesBenefits.checklist.title
                    p.ui-text.services-benefits__checklist-text= servicesBenefits.checklist.text
                    ul.services-benefits__checklist-list
                        each item in servicesBenefits.checklist.items
                            +checkListItem(item)
                .services-benefits__visual(aria-hidden="true")
                    //- .services-benefits__visual-decor
                    //-     img(src="/static/images/section/services-benefits/services-benefits-offer-decor.png" alt="")
                    .services-benefits__visual-image
                        img(src="/static/images/section/services-benefits/services-benefits-offer-person.png" alt="" loading="lazy")
