include ../../includes/media.pug

mixin videoReviewCard(item)
    -
        var videoReviewAttrs = {
            href: item.videoSrc || "#",
            class: "video-review-card",
            "data-fancybox": "video-reviews",
            "data-type": "html5video",
            "data-html5video-format": "video/mp4",
            "data-width": item.videoWidth || "720",
            "data-height": item.videoHeight || "1280",
            "aria-label": item.alt || "Открыть видео отзыв"
        }

        if (item.caption) {
            videoReviewAttrs["data-caption"] = item.caption
        }

    a&attributes(videoReviewAttrs)
        .video-review-card__media
            +mediaImage({
                src: item.posterSrc,
                alt: item.alt,
                width: item.posterWidth,
                height: item.posterHeight,
                loading: "lazy",
                decoding: "async",
                sizes: "(max-width: 650px) 70vw, 23vw"
            })
            span.video-review-card__play(aria-hidden="true")
                svg(viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg")
                    rect(x="1" y="1" width="58" height="58" rx="29" fill="white" fill-opacity="0.16")
                    path(d="M24 18.5C24 17.3127 25.3049 16.595 26.303 17.23L43.3342 28.0708C44.257 28.6581 44.257 30.0019 43.3342 30.5892L26.303 41.43C25.3049 42.065 24 41.3473 24 40.16V18.5Z" fill="#E8BF80")
