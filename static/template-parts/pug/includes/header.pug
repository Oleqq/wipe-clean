include ../data/includes/header-data

mixin headerChevronIcon(className)
    svg(class=className viewBox="0 0 9 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true")
        path(d="M0.353516 0.353516L4.35352 4.35352L8.35352 0.353516" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round")

mixin headerArrowIcon(className)
    svg(class=className viewBox="0 0 30 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true")
        path(d="M21 2L28 9L21 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
        path(d="M2 9H28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")

