+popupShell({
    id: "popup-calc",
    className: "popup__dialog--wide popup__dialog--calc",
    titleId: "popup-calc-title",
    descriptionId: "popup-calc-description"
})
    .popup-form.popup-form--split.popup-form--calculator
        .popup-form__content
            .popup-form__head
                h2#popup-calc-title.popup-form__title Узнайте стоимость уборки
                p#popup-calc-description.popup-form__text Заполните форму ниже, чтобы мы оперативно посчитали стоимость уборки и сообщили ее вам. Наши менеджеры перезвонят вам в ближайшее время.
            form.popup-form__form(action="#" method="post" novalidate data-popup-demo-form data-popup-success="popup-status-success" data-popup-error="popup-status-error")
                fieldset.popup-form__fieldset
                    legend.popup-form__legend Площадь
                    .ui-choice-group.popup-form__choice-group(data-popup-choice-group)
                        each choice, choiceIndex in popupAreaChoices
                            button.ui-choice.popup-form__choice(class=choiceIndex === 0 ? "ui-choice--active" : "" type="button" aria-pressed=choiceIndex === 0 ? "true" : "false" data-popup-choice)
                                span.ui-choice__label
                                    != choice
                .popup-form__grid.popup-form__grid--two
                    +popupSelectField("popup-calc-service", "Услуги", "Выберите услугу", popupServiceOptions, "support-cleaning")
                    +popupSelectField("popup-calc-frequency", "Регулярность", "Выберите регулярность", popupFrequencyOptions, "single")
                .popup-form__grid.popup-form__grid--two
                    +popupTextField("popup-calc-name", "Ваше имя", "Введите имя и фамилию", { autocomplete: "name" })
                    +popupTextField("popup-calc-phone", "Номер телефона", "+7 _ _ _ _ _ _ _ _ _ _", { type: "tel", autocomplete: "tel-national" })
                .popup-form__actions
                    +popupAgreement("popup-calc-agreement", "Заполняя форму вы даете согласие на обработку персональных данных")
                    button.ui-btn.ui-btn--primary.popup-form__submit(type="submit")
