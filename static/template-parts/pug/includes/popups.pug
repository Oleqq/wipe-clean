mixin popupShell(config)
    -
        var popupShellConfig = config || {};
        var popupShellClassName = popupShellConfig.className ? " " + popupShellConfig.className : "";
        var popupShellTitleId = popupShellConfig.titleId ? popupShellConfig.titleId : "popup-title-" + popupShellConfig.id;
        var popupShellDescriptionId = popupShellConfig.descriptionId ? popupShellConfig.descriptionId : null;
    .popup(data-popup=popupShellConfig.id data-lenis-prevent hidden aria-hidden="true")
        button.popup__backdrop(type="button" tabindex="-1" aria-hidden="true" data-popup-close)
        .popup__dialog(class=popupShellClassName data-lenis-prevent role="dialog" aria-modal="true" aria-labelledby=popupShellTitleId aria-describedby=popupShellDescriptionId)
            button.popup__close(type="button" aria-label="Закрыть попап" data-popup-close)
                +popupCloseIcon("popup__close-icon")
            block

mixin popupTextField(id, label, placeholder, options)
    -
        var popupTextOptions = options || {};
        var popupTextType = popupTextOptions.type ? popupTextOptions.type : "text";
        var popupTextTag = popupTextOptions.tag ? popupTextOptions.tag : "input";
        var popupTextRequired = popupTextOptions.required === false ? false : true;
        var popupTextName = popupTextOptions.name ? popupTextOptions.name : id;
        var popupTextRows = popupTextOptions.rows ? popupTextOptions.rows : 6;
        var popupTextAutocomplete = popupTextOptions.autocomplete ? popupTextOptions.autocomplete : null;
        var popupTextInputmode = popupTextOptions.inputmode ? popupTextOptions.inputmode : (popupTextType === "tel" ? "tel" : (popupTextType === "email" ? "email" : null));
        var popupTextEnterkeyhint = popupTextOptions.enterkeyhint ? popupTextOptions.enterkeyhint : null;
    .ui-field.popup-form__field
        label.ui-field__label(for=id)= label
        if popupTextTag === "textarea"
            textarea(id=id name=popupTextName rows=popupTextRows placeholder=placeholder required=popupTextRequired autocomplete=popupTextAutocomplete enterkeyhint=popupTextEnterkeyhint)
        else
            input(id=id type=popupTextType name=popupTextName placeholder=placeholder required=popupTextRequired autocomplete=popupTextAutocomplete inputmode=popupTextInputmode enterkeyhint=popupTextEnterkeyhint)

mixin popupSelectField(id, label, placeholder, options, selectedValue)
    -
        var popupSelectOptions = Array.isArray(options) ? options : [];
        var popupSelectSelectedValue = selectedValue ? selectedValue : "";
    .ui-field.popup-form__field
        label.ui-field__label(for=id)= label
        .popup-form__select
            select(id=id name=id required)
                if placeholder
                    option(value="" disabled selected=popupSelectSelectedValue === "")= placeholder
                each optionItem in popupSelectOptions
                    option(value=optionItem.value selected=optionItem.value === popupSelectSelectedValue)= optionItem.label
            span.popup-form__select-icon(aria-hidden="true")
                +popupChevronIcon("popup-form__select-icon-svg")

mixin popupAgreement(id, text)
    label.ui-checkbox.popup-form__checkbox(for=id)
        input.ui-checkbox__input(id=id type="checkbox" name=id required)
        span.ui-checkbox__label= text

include ../data/includes/popups-data

+popupShell({
    id: "popup-review",
    className: "popup__dialog--review",
    titleId: "popup-review-title",
    descriptionId: "popup-review-description"
})
    .popup-form.popup-form--review
        .popup-form__head
            h2#popup-review-title.popup-form__title
                | Оставьте свой отзыв о <br>
               
                | работе компании ВАЙП-Клин
            p#popup-review-description.popup-form__text Для нас будет очень ценно, если вы поделитесь своим отзывом о нашей работе. Так же будем рады, если к своему отзыву вы прикрепите фотографии или видео.
        form.popup-form__form(action="#" method="post" novalidate data-popup-demo-form data-popup-success="popup-status-success" data-popup-error="popup-status-error")
            .popup-form__grid.popup-form__grid--three
                +popupTextField("popup-review-name", "Ваше имя", "Введите имя и фамилию", { autocomplete: "name" })
                +popupTextField("popup-review-phone", "Номер телефона", "+7 _ _ _ _ _ _ _ _ _ _", { type: "tel", autocomplete: "tel-national" })
                +popupTextField("popup-review-email", "Email", "Ваша электронная почта", { type: "email", autocomplete: "email" })
            .popup-form__grid.popup-form__grid--two
                +popupTextField("popup-review-message", "Ваш отзыв", "Описание отзыва ...", { tag: "textarea", rows: 7 })
                .popup-upload(data-popup-upload)
                    span.ui-field__label.popup-upload__label Фото или видео
                    label.popup-upload__zone(for="popup-review-files")
                        input.popup-upload__input#popup-review-files(type="file" name="files" accept="image/jpeg,image/png,video/mp4" multiple hidden data-popup-upload-input)
                        .popup-upload__empty(data-popup-upload-empty)
                            span.popup-upload__badge
                                +popupUploadIcon("popup-upload__badge-icon")
                            .popup-upload__copy
                                p.popup-upload__title Добавьте картинку или видео
                                p.popup-upload__text JPEG, PNG или MP4, не больше 20 МБ
                        .popup-upload__preview(hidden data-popup-upload-preview)
            .popup-form__actions
                +popupAgreement("popup-review-agreement", "Заполняя форму вы даете согласие на обработку персональных данных")
                button.ui-btn.ui-btn--primary.popup-form__submit(type="submit")
                    span.ui-btn__content Оставить отзыв

