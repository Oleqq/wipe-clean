-
    var beforeAfterResultsData = typeof beforeAfterResultsSection === "object" && beforeAfterResultsSection ? beforeAfterResultsSection : {}
    var beforeAfterResultsButtonData = typeof beforeAfterResultsData.button === "object" && beforeAfterResultsData.button ? beforeAfterResultsData.button : {}
    var beforeAfterResultsOptions = Object.assign({}, beforeAfterResultsDefaults, beforeAfterResultsData)
    var beforeAfterResultsButton = Object.assign({}, beforeAfterResultsDefaults.button, beforeAfterResultsButtonData)
    var beforeAfterResultsItems = Array.isArray(beforeAfterResultsData.items) && beforeAfterResultsData.items.length ? beforeAfterResultsData.items : beforeAfterResultsDefaults.items

section.before-after-results
    ._container(
        data-before-after-results
        data-initial-desktop=beforeAfterResultsOptions.initialDesktop
        data-initial-mobile=beforeAfterResultsOptions.initialMobile
        data-step-desktop=beforeAfterResultsOptions.stepDesktop
        data-step-mobile=beforeAfterResultsOptions.stepMobile
    )
        .before-after-results__wrapper
            .before-after-results__head.ui-section-head.ui-section-head--center
                h2.before-after-results__title.ui-title
                    each line, index in beforeAfterResultsOptions.titleLines
                        | #{line}
                        if index !== beforeAfterResultsOptions.titleLines.length - 1
                            br

            .before-after-results__grid
                each item, index in beforeAfterResultsItems
                    .before-after-results__item(data-before-after-item data-item-index=index)
                        +beforeAfterCard(item)

            button.before-after-results__more.ui-btn(
                class=beforeAfterResultsButton.className
                type="button"
                data-before-after-more
            )
                span.ui-btn__content
                    span.before-after-results__more-label.before-after-results__more-label--default= beforeAfterResultsButton.label
                    span.before-after-results__more-label.before-after-results__more-label--loading= beforeAfterResultsButton.loadingLabel
