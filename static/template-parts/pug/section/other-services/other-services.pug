-
    var otherServicesData = typeof otherServicesSection === "object" && otherServicesSection ? otherServicesSection : {}
    var otherServicesButtonData = typeof otherServicesData.button === "object" && otherServicesData.button ? otherServicesData.button : {}
    var otherServicesOptions = Object.assign({}, otherServicesDefaults, otherServicesData)
    var otherServicesButton = Object.assign({}, otherServicesDefaults.button, otherServicesButtonData)
    var otherServicesCards = Array.isArray(otherServicesData.cards) && otherServicesData.cards.length ? otherServicesData.cards : otherServicesDefaults.cards

section.other-services
    ._container
        .other-services__wrapper
            .other-services__head.ui-section-head.ui-section-head--center
                h2.other-services__title.ui-title= otherServicesOptions.title
                p.other-services__text.ui-text= otherServicesOptions.text

            .other-services__grid
                each item in otherServicesCards
                    +serviceCard(item, "lg")

            a.other-services__action.ui-btn(class=otherServicesButton.className href=otherServicesButton.href)
                span.ui-btn__content
                    span.other-services__action-label.other-services__action-label--desktop= otherServicesButton.labelDesktop
                    span.other-services__action-label.other-services__action-label--mobile= otherServicesButton.labelMobile
