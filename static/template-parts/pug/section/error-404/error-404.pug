include ../../components/contact-panel/contact-panel

-
    var error404Defaults = {
        kicker: "Ой ...",
        title: "Страница не найдена",
        text: "Воспользуйтесь навигационым меню для перехода на другие страницы",
        homeAction: {
            label: "На главную",
            href: "/index.html"
        },
        servicesAction: {
            label: "Наши услуги",
            href: "/services.html"
        },
        contactsTitle: "Контакты клининговой компании ВАЙП–Клин",
        formTitle: "Форма заявки",
        idPrefix: "error-404",
        nameLabel: "Ваше имя",
        namePlaceholder: "Введите имя и фамилию",
        phoneLabel: "Номер телефона",
        phonePlaceholder: "+7 _ _ _ _ _ _ _ _ _ _",
        agreementText: "Заполняя форму вы даете согласие на обработку персональных данных",
        submitText: "Узнать стоимость клининга",
        submitTextMobile: "Рассчитать стоимость",
        phoneCard: {
            label: "Номер телефона",
            value: "+7 980 163 6101",
            href: "tel:+79801636101"
        },
        socialCard: {
            type: "socials",
            label: "Электронная почта",
            items: [
                {
                    label: "Telegram",
                    href: "#",
                    iconSrc: "/static/images/section/contacts/akar-icons_telegram-fill.png"
                },
                {
                    label: "WhatsApp",
                    href: "#",
                    iconSrc: "/static/images/section/contacts/Vector.png"
                },
                {
                    label: "VK",
                    href: "#",
                    iconSrc: "/static/images/section/contacts/Vector (1).png"
                }
            ]
        },
        emailCard: {
            label: "Электронная почта",
            value: "MAILBOX@WIPECLEAN.RU",
            href: "mailto:mailbox@wipeclean.ru"
        }
    };

-
    var error404Data = typeof error404Section === "object" && error404Section ? error404Section : {};
    var error404Options = Object.assign({}, error404Defaults, error404Data);
    var error404PhoneCard = typeof error404Data.phoneCard === "object" && error404Data.phoneCard ? error404Data.phoneCard : {};
    var error404SocialCard = typeof error404Data.socialCard === "object" && error404Data.socialCard ? error404Data.socialCard : {};
    var error404EmailCard = typeof error404Data.emailCard === "object" && error404Data.emailCard ? error404Data.emailCard : {};

    error404Options.phoneCard = Object.assign({}, error404Defaults.phoneCard, error404PhoneCard);
    error404Options.socialCard = Object.assign({}, error404Defaults.socialCard, error404SocialCard);
    error404Options.emailCard = Object.assign({}, error404Defaults.emailCard, error404EmailCard);

section.error-404
    ._container
        .error-404__wrapper
            .error-404__hero
                .error-404__head.ui-section-head
                    span.ui-kicker.error-404__kicker= error404Options.kicker
                    h1.ui-title.ui-title--hero.error-404__title= error404Options.title
                    p.ui-text.error-404__text= error404Options.text
                    .error-404__actions
                        a.ui-btn.ui-btn--primary.error-404__action(href=error404Options.homeAction.href)
                            span.ui-btn__content= error404Options.homeAction.label
                        a.ui-btn.ui-btn--secondary.error-404__action(href=error404Options.servicesAction.href)
                            span.ui-btn__content= error404Options.servicesAction.label
                .error-404__visual
                    img.error-404__image(src="/static/images/section/error-404/png.png" alt="" aria-hidden="true" loading="lazy")
            -
                var error404ContactPanelData = {
                    title: error404Options.contactsTitle,
                    formTitle: error404Options.formTitle,
                    idPrefix: error404Options.idPrefix,
                    nameLabel: error404Options.nameLabel,
                    namePlaceholder: error404Options.namePlaceholder,
                    phoneLabel: error404Options.phoneLabel,
                    phonePlaceholder: error404Options.phonePlaceholder,
                    agreementText: error404Options.agreementText,
                    submitText: error404Options.submitText,
                    submitTextMobile: error404Options.submitTextMobile,
                    phoneCard: error404Options.phoneCard,
                    socialCard: error404Options.socialCard,
                    emailCard: error404Options.emailCard
                };

            +contactPanel(error404ContactPanelData, "error-404__contacts")
