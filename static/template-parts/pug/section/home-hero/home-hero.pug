                                path(d="M26.6667 16.6667C28.9679 16.6667 30.8333 14.8012 30.8333 12.5C30.8333 10.1988 28.9679 8.33334 26.6667 8.33334" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M35 31.6667C35 27.5245 31.6419 24.1667 27.5 24.1667" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round")
