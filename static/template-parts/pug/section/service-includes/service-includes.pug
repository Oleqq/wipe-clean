    function getHotspotStyle(item) {
        return "--hotspot-x-desktop:" + item.xDesktop + "%;" +
            "--hotspot-y-desktop:" + item.yDesktop + "%;" +
            "--hotspot-x-mobile:" + item.xMobile + "%;" +
            "--hotspot-y-mobile:" + item.yMobile + "%;"
    }

    function getTooltipStyle(item) {
        return "--tooltip-x-desktop:" + item.tooltipXDesktop + "%;" +
            "--tooltip-y-desktop:" + item.tooltipYDesktop + "%;" +
            "--tooltip-x-mobile:" + item.tooltipXMobile + "%;" +
            "--tooltip-y-mobile:" + item.tooltipYMobile + "%;" +
            "--tooltip-width-desktop:" + item.tooltipWidthDesktop + "px;" +
            "--tooltip-width-mobile:" + item.tooltipWidthMobile + "px;"
    }

section.service-includes(data-service-includes)
    ._container
        .service-includes__wrapper
            .service-includes__content
                .service-includes__head
                    h2.ui-title.service-includes__title= serviceIncludesData.title
                    p.ui-text.service-includes__text= serviceIncludesData.text

                .service-includes__tabs(role="tablist" aria-label=serviceIncludesData.title)
                    each tab, index in serviceIncludesData.tabs
                        -
                            var tabId = serviceIncludesData.idPrefix + "-tab-" + tab.id
                            var panelId = serviceIncludesData.idPrefix + "-panel-" + tab.id
                            var isActiveTab = index === 0
                        button.service-includes__tab(
                            id=tabId
                            class=isActiveTab ? "is-active" : ""
                            type="button"
                            role="tab"
                            data-service-includes-tab
                            data-tab-id=tab.id
                            aria-selected=isActiveTab ? "true" : "false"
                            aria-controls=panelId
                            tabindex=isActiveTab ? "0" : "-1"
                        )
                            span.service-includes__tab-label= tab.label
                            span.service-includes__tab-icon(aria-hidden="true")
                                +serviceIncludesArrow()

            .service-includes__visual
                .service-includes__visual-stage
                    each tab, tabIndex in serviceIncludesData.tabs
                        -
                            var panelId = serviceIncludesData.idPrefix + "-panel-" + tab.id
                            var labelledBy = serviceIncludesData.idPrefix + "-tab-" + tab.id
                            var activeHotspotId = tab.activeHotspotId || tab.hotspots[0].id
                            var isActivePanel = tabIndex === 0
                        .service-includes__panel(
                            id=panelId
                            class=isActivePanel ? "is-active" : ""
                            role="tabpanel"
                            data-service-includes-panel
                            data-tab-id=tab.id
                            aria-labelledby=labelledBy
                            aria-hidden=isActivePanel ? "false" : "true"
                        )
                            .service-includes__panel-image
                                img(src=tab.imageSrc alt=tab.imageAlt loading="lazy")

                            each hotspot, hotspotIndex in tab.hotspots
                                -
                                    var hotspotButtonId = serviceIncludesData.idPrefix + "-hotspot-" + tab.id + "-" + hotspot.id
                                    var tooltipId = serviceIncludesData.idPrefix + "-tooltip-" + tab.id + "-" + hotspot.id
                                    var isActiveHotspot = hotspot.id === activeHotspotId
                                button.service-includes__hotspot(
                                    id=hotspotButtonId
                                    class=isActiveHotspot ? "is-active" : ""
                                    type="button"
                                    data-service-includes-hotspot
                                    data-hotspot-id=hotspot.id
                                    aria-controls=tooltipId
                                    aria-expanded=isActiveHotspot ? "true" : "false"
                                    tabindex=isActivePanel ? "0" : "-1"
                                    style=getHotspotStyle(hotspot)
                                )
                                    span.service-includes__hotspot-core(aria-hidden="true")

                            .service-includes__tooltips
                                each hotspot in tab.hotspots
                                    -
                                        var tooltipId = serviceIncludesData.idPrefix + "-tooltip-" + tab.id + "-" + hotspot.id
                                        var isActiveHotspot = hotspot.id === activeHotspotId
                                    .service-includes__tooltip(
                                        id=tooltipId
                                        class=isActiveHotspot ? "is-active" : ""
                                        role="tooltip"
                                        data-service-includes-tooltip
                                        data-hotspot-id=hotspot.id
                                        aria-hidden=isActiveHotspot ? "false" : "true"
                                        style=getTooltipStyle(hotspot)
                                    )
                                        p.service-includes__tooltip-text= hotspot.tooltip
