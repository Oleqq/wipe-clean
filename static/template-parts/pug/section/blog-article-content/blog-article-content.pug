mixin articleFeatureItem(item)
    article.entry-content__feature
        h3.entry-content__feature-title= item.title
        p.entry-content__feature-text= item.text

mixin articleListItem(item)
    li.entry-content__list-item
        if item.title
            strong= item.title + " "
        | #{item.text}

mixin renderArticleBlock(articleBlock)
    if articleBlock && articleBlock.type
        case articleBlock.type
            when "section"
                section.entry-content__section
                    if articleBlock.title
                        h2= articleBlock.title
                    if Array.isArray(articleBlock.paragraphs)
                        each paragraph in articleBlock.paragraphs
                            p= paragraph
            when "feature-section"
                section.entry-content__section
                    if articleBlock.title
                        h2= articleBlock.title
                    if articleBlock.lead
                        p= articleBlock.lead
                    if Array.isArray(articleBlock.items) && articleBlock.items.length
                        .entry-content__feature-list
                            each item in articleBlock.items
                                +articleFeatureItem(item)
                    if articleBlock.outro
                        p= articleBlock.outro
            when "list-section"
                section.entry-content__section
                    if articleBlock.title
                        h2= articleBlock.title
                    if Array.isArray(articleBlock.paragraphs)
                        each paragraph in articleBlock.paragraphs
                            p= paragraph
                    if articleBlock.listLead
                        p.entry-content__list-lead= articleBlock.listLead
                    if Array.isArray(articleBlock.items) && articleBlock.items.length
                        ul.entry-content__list
                            each item in articleBlock.items
                                +articleListItem(item)
                    if articleBlock.outro
                        p= articleBlock.outro
            when "figure"
                figure.entry-content__figure
                    img(src=articleBlock.image.src alt=articleBlock.image.alt loading="lazy")

