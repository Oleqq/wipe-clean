-
    var blogArticleContentData = typeof blogArticleContentSection === "object" && blogArticleContentSection ? blogArticleContentSection : {}
    var blogArticleContentOptions = Object.assign({}, blogArticleContentDefaults, blogArticleContentData)
    var blogArticleContentBlocks = Array.isArray(blogArticleContentOptions.blocks) && blogArticleContentOptions.blocks.length ? blogArticleContentOptions.blocks : blogArticleContentDefaults.blocks

section.blog-article-content
    ._container
        .blog-article-content__wrapper
            article.blog-article-content__article.entry-content
                each articleBlock in blogArticleContentBlocks
                    +renderArticleBlock(articleBlock)
