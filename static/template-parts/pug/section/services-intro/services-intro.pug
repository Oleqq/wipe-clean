section.services-intro
    ._container
        .services-intro__wrapper
            .services-intro__hero
                .services-intro__hero-head.ui-section-head
                    span.ui-kicker.services-intro__hero-kicker= servicesIntro.hero.kicker
                    h1.ui-title.ui-title--hero.services-intro__hero-title= servicesIntro.hero.title
                .services-intro__hero-media(aria-hidden="true")
                    .services-intro__hero-decor
                        img(src="/static/images/section/services-hero/services-hero-decor.png" alt="")
                    .services-intro__hero-cleaner
                        img(src="/static/images/section/services-hero/services-hero-cleaner.png" alt="" loading="eager" fetchpriority="high")
                    .services-intro__hero-interior
                        img(src="/static/images/section/services-hero/services-hero-interior.png" alt="" loading="eager")
                .services-intro__hero-content
                    p.ui-text.services-intro__hero-text= servicesIntro.hero.text
                    .services-intro__hero-actions
                        each action in servicesIntro.hero.actions
                            a.ui-btn.services-intro__hero-action(class=action.className href=action.href)
                                span.ui-btn__content= action.label
            .services-intro__overview
                .services-intro__overview-content
                    h2.ui-title.services-intro__overview-title= servicesIntro.overview.title
                    .services-intro__overview-copy(data-read-more)
                        .services-intro__overview-summary
                            p.ui-text.services-intro__overview-summary-text
                                | #{servicesIntro.overview.summary} 
                                button.services-intro__overview-more(type="button" data-read-more-toggle aria-expanded="false" aria-controls=servicesIntro.overview.bodyId) Ещё
                        .services-intro__overview-body(id=servicesIntro.overview.bodyId)
                            each paragraph in servicesIntro.overview.paragraphs
                                p.ui-text.services-intro__overview-text= paragraph
                .services-intro__overview-media(aria-hidden="true")
                    img(src="/static/images/section/services-intro/services-intro-tools.png" alt="" loading="lazy")
            .services-intro__slider.swiper(data-services-intro-swiper)
                .services-intro__slider-track.swiper-wrapper
                    each item in servicesIntro.cards
                        .services-intro__slide.swiper-slide
                            +serviceTeaserCard(item)
            .services-intro__footer
                .services-intro__actions
                    each action in servicesIntro.actions
                        a.ui-btn.services-intro__action(class=action.className href=action.href)
                            span.ui-btn__content= action.label
                .services-intro__nav.ui-slider-nav.ui-slider-nav--desktop-only
                    button.services-intro__nav-btn.ui-btn.ui-btn--primary.ui-slider-nav__btn(type="button" aria-label="Предыдущая услуга" data-services-intro-prev)
                        span.ui-btn__content
                            svg(width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg")
                                path(d="M28 18H8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M16 10L8 18L16 26" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round")
                    button.services-intro__nav-btn.ui-btn.ui-btn--primary.ui-slider-nav__btn(type="button" aria-label="Следующая услуга" data-services-intro-next)
                        span.ui-btn__content
                            svg(width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg")
                                path(d="M8 18H28" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M20 10L28 18L20 26" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round")
